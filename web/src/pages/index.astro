 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n          <svg viewBox=\"0 0 20 20\" fill=\"#FFB930\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n          <svg viewBox=\"0 0 20 20\" fill=\"#FFB930\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n        </div>\r\n        <p>Pedimos presupuesto para cambiar dos aires acondicionados de sitio por una mudanza. Todo se gestionó rápido y con mucha seriedad; repetiríamos sin dudarlo.</p>\r\n        <div class=\"who\"><div class=\"avatar-sm\">A</div><div><h5>Cliente en Coslada</h5><span>Instalación de aire acondicionado</span></div></div>\r\n      </div>\r\n      <div class=\"review-card\">\r\n        <div class=\"stars\">\r\n          <svg viewBox=\"0 0 20 20\" fill=\"#FFB930\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n          <svg viewBox=\"0 0 20 20\" fill=\"#FFB930\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n          <svg viewBox=\"0 0 20 20\" fill=\"#FFB930\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n          <svg viewBox=\"0 0 20 20\" fill=\"#FFB930\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n          <svg viewBox=\"0 0 20 20\" fill=\"#FFB930\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n        </div>\r\n        <p>Un técnico de otra empresa había dado la caldera por perdida. Decogas vino, la revisó y consiguió repararla. Muy agradecida con su trabajo.</p>\r\n        <div class=\"who\"><div class=\"avatar-sm\">L</div><div><h5>Cliente en Madrid</h5><span>Reparación de caldera</span></div></div>\r\n      </div>\r\n      <div class=\"review-card\">\r\n        <div class=\"stars\">\r\n          <svg viewBox=\"0 0 20 20\" fill=\"