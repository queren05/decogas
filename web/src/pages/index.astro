erved\": { \"@type\": \"AdministrativeArea\", \"name\": \"Comunidad de Madrid\" },\n  \"sameAs\": [\"https://www.facebook.com/somosdecogas\"],\n  \"priceRange\": \"€€\"\n}\n</script>";
const body = "<!-- HERO -->\r\n<section class=\"hero\" id=\"top\">\r\n  <div class=\"hero-orb orb-1\"></div>\r\n  <div class=\"hero-orb orb-2\"></div>\r\n  <div class=\"hero-orb orb-3\"></div>\r\n  <div class=\"wrap\">\r\n    <div>\r\n      <div class=\"eyebrow\" style=\"color:var(--flame);\">Empresa familiar · Madrid · desde hace más de 15 años</div>\r\n      <h1>Somos las personas que <span class=\"accent\">cuidan</span> del confort de tu casa.</h1>\r\n      <p class=\"lead\">Decogas es un equipo de instaladores propios, certificados y de trato cercano, especializado en calderas y aire acondicionado en toda la Comunidad de Madrid. Nos conocen por cómo trabajamos, no solo por lo que instalamos.</p>\r\n      <div class=\"hero-ctas\">\r\n        <a href=\"#contacto\" class=\"btn btn-flame\">Pide información sin compromiso</a>\r\n        <a href=\"#resenas\" class=\"btn btn-ghost\">Ver reseñas reales</a>\r\n      </div>\r\n      <div class=\"hero-stats\">\r\n        <div class=\"stat\"><div class=\"num\"><span class=\"counter\" data-target=\"15\">0</span><span class=\"suffix\">+</span></div><div class=\"lbl\">Años de trayectoria</div></div>\r\n        <div class=\"stat\"><div class=\"num\"><span class=\"counter\" data-target=\"780\">0</span><span class=\"suffix\">+</span></div><div class=\"lbl\">Reseñas en Google</div></div>\r\n        <div class=\"stat\"><div class=\"num\">4.7<span class=\"suffix\">★</span></div><div class=\"lbl\">Valoración media</div></div>\r\n        <div class=\"stat\"><div class=\"num\"><span class=\"counter\" data-target=\"3\">0</span></div><div class=\"lbl\">Años de garantía</div></div>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"rating-card reveal\">\r\n      <div class=\"rating-top\">\r\n        <svg class=\"g-icon\" viewBox=\"0 0 48 48\"><path fill=\"#FFC107\" d=\"M43.6 20.5H24v7.9h11.3C34.2 33.6 29.6 37 24 37c-7.2 0-13-5.8-13-13s5.8-13 13-13c3.3 0 6.3 1.2 8.6 3.2l6-6C34.9 4.2 29.7 2 24 2 11.9 2 2 11.9 2 24s9.9 22 22 22 21-8.7 21-