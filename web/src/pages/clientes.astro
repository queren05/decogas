---
// Página autónoma (panel privado): head propio con estilos en línea, sin el layout de marketing.
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const V = 21;
const css = "\r\n  :root{\r\n    --navy:#0E2238; --navy-2:#16324B; --flame:#FF6B35; --flame-deep:#E2501C; --ice:#3AA6D9;\r\n    --gold:#FFB930; --cloud:#F3F6F9; --line:#E2E8EF; --muted:#5B6B7B; --ok:#1E9E5A; --err:#D8433B;\r\n  }\r\n  *{ margin:0; padding:0; box-sizing:border-box; }\r\n  body{ font-family:'Inter',sans-serif; background:var(--cloud); color:var(--navy); min-height:100vh; overflow-x:hidden; }\r\n  @media(max-width:640px){\r\n    .wrap{ padding:0 14px; }\r\n    .filters-card, .lead{ padding:14px; }\r\n    .admin-topbar h1{ font-size:20px; }\r\n    .admin-topbar .right{ flex-wrap:wrap; }\r\n    .stat-card .num{ font-size:26px; }\r\n  }\r\n  h1,h2,h3{ font-family:'Fraunces',serif; }\r\n  button{ font-family:'Inter',sans-serif; cursor:pointer; }\r\n\r\n  #loginScreen{\r\n    position:fixed; inset:0; display:flex; align-items:center; justify-content:center; padding:20px;\r\n    background:\r\n      radial-gradient(90% 120% at 85% -10%, rgba(58,166,217,.30), transparent 55%),\r\n      radial-gradient(70% 90% at 5% 110%, rgba(255,107,53,.22), transparent 55%),\r\n      linear-gradient(160deg, #0E2238 0%, #081729 100%);\r\n    overflow:hidden; z-index:50; transition:opacity .5s, visibility .5s;\r\n  }\r\n  #loginScreen.hidden{ opacity:0; visibility:hidden; }\r\n  .orb{ position:absolute; border-radius:50%; filter:blur(60px); opacity:.5; animation:float 9s ease-in-out infinite; }\r\n  .orb.o1{ width:340px; height:340px; background:var(--ice); top:-90px; right:-60px; }\r\n  .orb.o2{ width:280px; height:280px; background:var(--flame); bottom:-70px; left:-50px; animation-delay:-3s; }\r\n  @keyframes float{ 0%,100%{ transform:translateY(0) scale(1); } 50%{ transform:translateY(-26px) scale(1.05); } }\r\n  .login-card{\r\n    position:relative; z-index:1; width:100%; max-width:420px; background:rgba(255,255,255,.98);\r\n    border-radius:20px; padding:40px 36px 34px; box-shadow:0 30px 80px rgba(0,0,0,.35);\r\n    animation:cardIn .7s cubic-bezier(.22,1,.36,1) both;\r\n  }\r\n  @keyframes cardIn{ from{ opacity:0; transform:translateY(26px) scale(.97); } to{ opacity:1; transform:none; } }\r\n  .login-logo{ display:flex; align-items:center; gap:12px; margin-bottom:8px; }\r\n  .login-logo .mark{\r\n    width:44px; height:44px; border-radius:12px; background:var(--navy); color:#fff; display:flex;\r\n    align-items:center; justify-content:center; font-family:'Fraunces'; font-weight:700; font-size:22px; position:relative; overflow:hidden;\r\n  }\r\n  .login-logo .mark::after{ content:\"\"; position:absolute; inset:0;\r\n    background:radial-gradient(60% 60% at 70% 30%, rgba(58,166,217,.55), transparent 70%),\r\n               radial-gradient(60% 60% at 25% 80%, rgba(255,107,53,.55), transparent 70%); }\r\n  .login-logo .mark span{ position:relative; z-index:1; }\r\n  .login-logo h1{ font-size:24px; }\r\n  .login-sub{ font-size:13.5px; color:var(--muted); margin-bottom:26px; }\r\n  .field{ margin-bottom:16px; }\r\n  .field label{ display:block; font-size:12.5px; font-weight:600; margin-bottom:6px; }\r\n  .field input{ width:100%; padding:12px 14px; border:1.5px solid var(--line); border-radius:10px; font-size:14.5px; font-family:'Inter'; }\r\n  .field input:focus{ outline:none; border-color:var(--ice); box-shadow:0 0 0 3px rgba(58,166,217,.15); }\r\n  .btn{ display:inline-flex; align-items:center; justify-content:center; gap:8px; padding:13px 24px;\r\n    border-radius:11px; border:none; background:var(--flame); color:#fff; font-weight:600; font-size:14.5px;\r\n    transition:transform .2s, background .2s; box-shadow:0 6px 18px rgba(255,107,53,.35); text-decoration:none; }\r\n  .btn:hover{ background:var(--flame-deep); transform:translateY(-2px); }\r\n  .btn:active{ transform:translateY(0) scale(.97); }\r\n  .btn.ghost{ background:transparent; color:var(--muted); border:1.5px solid var(--line); box-shadow:none; }\r\n  .btn.ghost:hover{ color:var(--navy); border-color:var(--muted); background:#fff; }\r\n  .btn.small{ padding:9px 16px; font-size:13px; border-radius:9px; }\r\n  .btn.block{ width:100%; }\r\n  .msg{ font-size:13.5px; margin-top:12px; display:none; color:var(--err); }\r\n  .msg.show{ display:block; }\r\n\r\n  #panel{ display:none; }\r\n  .admin-header{ background:linear-gradient(160deg, #0E2238 0%, #12293F 100%); color:#fff; padding:26px 0 74px; position:relative; overflow:hidden; }\r\n  .admin-header .orb{ opacity:.35; }\r\n  .wrap{ max-width:960px; margin:0 auto; padding:0 20px; position:relative; z-index:1; }\r\n  .admin-topbar{ display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap; }\r\n  .admin-topbar h1{ font-size:24px; }\r\n  .admin-topbar .right{ display:flex; align-items:center; gap:10px; }\r\n  .admin-sub{ margin-top:10px; font-size:14px; color:rgba(255,255,255,.75); max-width:560px; line-height:1.55; }\r\n  .panel-body{ margin-top:-44px; padding-bottom:90px; }\r\n\r\n  .stats-row{ display:grid; grid-template-columns:repeat(3, 1fr); gap:14px; margin-bottom:20px; }\r\n  @media(max-width:640px){\r\n    .stats-row{ grid-template-columns:repeat(3, 1fr); gap:9px; }\r\n    .stat-card{ padding:13px 10px; text-align:center; }\r\n    .stat-card .num{ font-size:24px; }\r\n    .stat-card .lbl{ font-size:9px; }\r\n  }\r\n  .stat-card{ background:#fff; border:1px solid var(--line); border-radius:14px; padding:20px; box-shadow:0 10px 30px rgba(14,34,56,.06); animation:cardIn .5s ease both; }\r\n  .stat-card .num{ font-family:'Fraunces',serif; font-size:32px; font-weight:700; color:var(--flame-deep); }\r\n  .stat-card .lbl{ font-family:'IBM Plex Mono'; font-size:10.5px; letter-spacing:.07em; text-transform:uppercase; color:var(--muted); margin-top:4px; }\r\n\r\n  .filters-card{ background:#fff; border:1px solid var(--line); border-radius:14px; padding:18px; margin-bottom:20px; box-shadow:0 10px 30px rgba(14,34,56,.06); }\r\n  .filters-grid{ display:grid; grid-template-columns:1.4fr 1fr 1fr; gap:12px; margin-bottom:14px; }\r\n  @media(max-width:720px){ .filters-grid{ grid-template-columns:1fr; } }\r\n  .filters-card input{\r\n    width:100%; padding:11px 13px; border:1.5px solid var(--line); border-radius:10px;\r\n    font-family:'Inter'; font-size:14px; background:#fff; color:var(--navy);\r\n    -webkit-appearance:none; appearance:none; min-height:44px;\r\n  }\r\n  .filters-card input[type=\"date\"]{ display:block; text-align:left; }\r\n  .filters-card input[type=\"date\"]::-webkit-date-and-time-value{ text-align:left; }\r\n  .filters-card input:focus{ outline:none; border-color:var(--ice); }\r\n  .filters-card label{ display:block; font-size:11.5px; font-weight:600; color:var(--muted); margin-bottom:5px; }\r\n  .chips{ display:flex; gap:8px; flex-wrap:wrap; }\r\n  .chip{ padding:8px 16px; border-radius:999px; border:1.5px solid var(--line); background:#fff; font-weight:600; font-size:13px; color:var(--muted); transition:all .2s; }\r\n  .chip:hover{ border-color:var(--ice); color:var(--navy); }\r\n  .chip.active{ background:var(--navy); border-color:var(--navy); color:#fff; }\r\n\r\n  .lead{ background:#fff; border:1px solid var(--line); border-radius:13px; padding:16px 18px; margin-bottom:11px;\r\n    transition:box-shadow .25s, border-color .25s; animation:cardIn .4s ease both; }\r\n  .lead:hover{ border-color:#CBD6E0; box-shadow:0 6px 16px rgba(14,34,56,.07); }\r\n  .lead-top{ display:flex; align-items:center; gap:12px; flex-wrap:wrap; }\r\n  .lead-name{ font-weight:700; font-size:15.5px; flex:1; min-width:0; overflow-wrap:anywhere; }\r\n  .lead-date{ font-family:'IBM Plex Mono'; font-size:11px; color:var(--muted); white-space:nowrap; }\r\n  .badge{ font-family:'IBM Plex Mono'; font-size:10.5px; font-weight:600; padding:5px 12px; border-radius:999px; white-space:nowrap; }\r\n  .badge.caldera{ background:#FFF3E8; color:var(--flame-deep); border:1px solid #FFD9C2; }\r\n  .badge.aire{ background:#EAF5FB; color:#1E7FAE; border:1px solid #C4E3F2; }\r\n  .badge.otro{ background:var(--cloud); color:var(--muted); border:1px solid var(--line); }\r\n  .lead-contact{ display:flex; gap:16px; flex-wrap:wrap; margin-top:8px; font-size:13.5px; }\r\n  .lead-contact a{ color:var(--navy); text-decoration:none; font-weight:600; display:inline-flex; align-items:center; gap:6px; }\r\n  .lead-contact a:hover{ color:var(--flame-deep); }\r\n  .lead-contact svg{ width:14px; height:14px; stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }\r\n  .lead-msg{ margin-top:10px; padding-top:10px; border-top:1px dashed var(--line); font-size:13.5px; color:var(--muted); line-height:1.6; }\r\n  .lead-del{\r\n    display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid #F2C7C4;\r\n    color:var(--err); font-size:12px; font-weight:600; padding:7px 13px; border-radius:9px; font-family:'Inter';\r\n    transition:all .2s;\r\n  }\r\n  .lead-del:hover{ background:#FDF1F0; border-color:var(--err); }\r\n  .empty-state{ text-align:center; padding:50px 20px; color:var(--muted); font-size:14.5px; background:#fff; border:1px dashed var(--line); border-radius:14px; }\r\n  /* ===== Mini-CRM: estado de solicitud, estadísticas, etiquetas ===== */\r\n  .lead-estado{ font-size:12px; font-weight:700; border-radius:999px; padding:6px 12px; border:1.5px solid var(--line); cursor:pointer; background:#fff; color:var(--navy); font-family:'Inter'; transition:border-color .2s, background .2s; }\r\n  .lead-estado:focus{ outline:none; border-color:var(--ice); box-shadow:0 0 0 3px rgba(58,166,217,.15); }\r\n  .lead-estado.est-pendiente{ background:#FFF3D6; border-color:#F2D48A; color:#8A6100; }\r\n  .lead-estado.est-llamado{ background:#E3F2FB; border-color:#A9D7F2; color:#0F5E8C; }\r\n  .lead-estado.est-presupuestado{ background:#E8EAF6; border-color:#B9C0E8; color:#2E3A8C; }\r\n  .lead-estado.est-cerrado{ background:#E8F6EC; border-color:#A9DFBB; color:#1C7C3C; }\r\n  .stats-pro{ display:grid; grid-template-columns:1.5fr 1fr; gap:22px; background:#fff; border:1px solid var(--line); border-radius:14px; padding:20px 22px; margin-bottom:20px; box-shadow:0 10px 30px rgba(14,34,56,.06); animation:cardIn .5s ease both; }\r\n  @media(max-width:720px){ .stats-pro{ grid-template-columns:1fr; gap:16px; } }\r\n  .stats-pro h4{ font-family:'IBM Plex Mono'; font-size:11px; text-transform:uppercase; letter-spacing:.07em; color:var(--muted); margin-bottom:12px; }\r\n  .sp-chart .sp-bars{ display:flex; align-items:flex-end; gap:8px; height:118px; }\r\n  .sp-col{ flex:1; display:flex; flex-direction:column; align-items:center; justify-content:flex-end; height:100%; gap:5px; }\r\n  .sp-n{ font-size:11px; font-weight:700; color:var(--navy); font-family:'IBM Plex Mono'; }\r\n  .sp-bar{ width:100%; max-width:30px; background:linear-gradient(180deg, var(--flame) 0%, var(--flame-deep) 100%); border-radius:6px 6px 3px 3px; min-height:4px; transition:height .4s cubic-bezier(.22,1,.36,1); }\r\n  .sp-lbl{ font-size:9.5px; color:var(--muted); white-space:nowrap; }\r\n  .sp-side h4{ margin-top:2px; }\r\n  .sp-side h4:not(:first-child){ margin-top:14px; }\r\n  .sp-tags{ display:flex; flex-wrap:wrap; gap:7px; }\r\n  .sp-tag{ font-size:12px; font-weight:600; border:1px solid var(--line); border-radius:999px; padding:5px 12px; color:var(--navy); background:var(--cloud); }\r\n  .sp-tag strong{ color:var(--flame-deep); }\r\n  .sp-tag.est-pendiente{ background:#FFF3D6; border-color:#F2D48A; color:#8A6100; }\r\n  .sp-tag.est-pendiente strong{ color:#8A6100; }\r\n  .sp-tag.est-llamado{ background:#E3F2FB; border-color:#A9D7F2; color:#0F5E8C; }\r\n  .sp-tag.est-llamado strong{ color:#0F5E8C; }\r\n  .sp-tag.est-presupuestado{ background:#E8EAF6; border-color:#B9C0E8; color:#2E3A8C; }\r\n  .sp-tag.est-presupuestado strong{ color:#2E3A8C; }\r\n  .sp-tag.est-cerrado{ background:#E8F6EC; border-color:#A9DFBB; color:#1C7C3C; }\r\n  .sp-tag.est-cerrado strong{ color:#1C7C3C; }\r\n\r\n  #toast{ position:fixed; bottom:26px; left:50%; transform:translate(-50%, 80px); background:var(--navy); color:#fff;\r\n    padding:13px 22px; border-radius:12px; font-size:14px; box-shadow:0 14px 34px rgba(0,0,0,.3);\r\n    transition:transform .4s cubic-bezier(.22,1,.36,1); z-index:100; }\r\n  #toast.show{ transform:translate(-50%, 0); }\r\n  #toast.err{ background:var(--err); } [data-theme=\"dark\"]{ --cloud:#0F1A25; --navy:#E6EEF6; --navy-2:#B9CBDC; --line:#26384B; --muted:#93A5B6; }[data-theme=\"dark\"] body{ background:#0B131C; }[data-theme=\"dark\"] .login-card{ background:#141F2C; }[data-theme=\"dark\"] input, [data-theme=\"dark\"] textarea, [data-theme=\"dark\"] select{ background:#0F1A25; color:#E6EEF6; }[data-theme=\"dark\"] input::placeholder, [data-theme=\"dark\"] textarea::placeholder{ color:#5F7488; }[data-theme=\"dark\"] .btn.ghost:hover{ background:#1B2A3A; }[data-theme=\"dark\"] .section-card, [data-theme=\"dark\"] .filters-card, [data-theme=\"dark\"] .stats-pro, [data-theme=\"dark\"] .prod, [data-theme=\"dark\"] .lead, [data-theme=\"dark\"] .stat-card{ background:#141F2C; }[data-theme=\"dark\"] .prod:hover, [data-theme=\"dark\"] .lead:hover{ border-color:#3A4C60; box-shadow:none; }[data-theme=\"dark\"] .prod.hidden-prod{ background:#0F1A25; }[data-theme=\"dark\"] .icon-btn, [data-theme=\"dark\"] .photo-thumb{ background:#1B2A3A; }[data-theme=\"dark\"] .chip{ background:#1B2A3A; border-color:#26384B; }[data-theme=\"dark\"] .chip.active{ background:#173A5C; color:#fff; border-color:#173A5C; }[data-theme=\"dark\"] .login-logo .mark{ background:#173A5C; }[data-theme=\"dark\"] #toast{ background:#1B2A3A; }[data-theme=\"dark\"] .switch .track{ background:#3A4C60; }[data-theme=\"dark\"] .prod-form{ background:#0F1A25; }[data-theme=\"dark\"] .prod-form-inner{ border-top-color:#26384B; }[data-theme=\"dark\"] .mode-pill.demo{ background:#3A2A18; border-color:#5A3D28; }[data-theme=\"dark\"] .mode-pill.live{ background:#12301F; border-color:#265F42; }[data-theme=\"dark\"] .add-btn{ border-color:#3A4C60; }[data-theme=\"dark\"] .add-btn:hover{ background:#2A2018; }[data-theme=\"dark\"] .empty-state{ background:#141F2C; }[data-theme=\"dark\"] .lead-msg, [data-theme=\"dark\"] .prod-form-inner{ border-color:#26384B; }[data-theme=\"dark\"] .theme-toggle-btn{ color:rgba(255,255,255,.85); }\r\n";
const body = "<div id=\"loginScreen\">\r\n  <div class=\"orb o1\"></div><div class=\"orb o2\"></div>\r\n  <div class=\"login-card\">\r\n    <div class=\"login-logo\">\r\n      <div class=\"mark\"><span>D</span></div>\r\n      <h1>Clientes Decogas</h1>\r\n    </div>\r\n    <p class=\"login-sub\">Solicitudes recibidas desde el formulario de la web.</p>\r\n    <form id=\"loginForm\">\r\n      <div class=\"field\">\r\n        <label for=\"adminEmail\">Email</label>\r\n        <input type=\"email\" id=\"adminEmail\" autocomplete=\"username\" required>\r\n      </div>\r\n      <div class=\"field\">\r\n        <label for=\"adminPass\">Contraseña</label>\r\n        <input type=\"password\" id=\"adminPass\" autocomplete=\"current-password\" required>\r\n      </div>\r\n      <button type=\"submit\" class=\"btn block\" id=\"loginBtn\">Entrar</button>\r\n      <p class=\"msg\" id=\"loginMsg\"></p>\r\n    </form>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"panel\">\r\n  <header class=\"admin-header\">\r\n    <div class=\"orb o1\"></div><div class=\"orb o2\"></div>\r\n    <div class=\"wrap\">\r\n      <div class=\"admin-topbar\">\r\n        <h1>Clientes</h1>\r\n        <div class=\"right\">\r\n          <button class=\"btn ghost small theme-toggle-btn\" id=\"themeToggle\" type=\"button\" title=\"Modo claro / oscuro\" aria-label=\"Cambiar tema\" style=\"color:rgba(255,255,255,.85); border-color:rgba(255,255,255,.3);\">\u25D0</button>\r\n          <a class=\"btn ghost small\" href=\"admin.html\" style=\"color:rgba(255,255,255,.8); border-color:rgba(255,255,255,.3);\">← Panel de catálogo</a>\r\n          <button class=\"btn ghost small\" id=\"logoutBtn\" type=\"button\" style=\"color:rgba(255,255,255,.8); border-color:rgba(255,255,255,.3);\">Salir</button>\r\n        </div>\r\n      </div>\r\n      <p class=\"admin-sub\">Cada persona que envía el formulario de la web aparece aquí al instante, y además recibes un aviso por correo con sus datos.</p>\r\n    </div>\r\n  </header>\r\n\r\n  <div class=\"panel-body\">\r\n    <div class=\"wrap\">\r\n      <div class=\"stats-row\">\r\n        <div class=\"stat-card\"><div class=\"num\" id=\"statTotal\">0</div><div class=\"lbl\">Clientes totales</div></div>\r\n        <div class=\"stat-card\" style=\"animation-delay:.07s;\"><div class=\"num\" id=\"statMes\">0</div><div class=\"lbl\">Este mes</div></div>\r\n        <div class=\"stat-card\" style=\"animation-delay:.14s;\"><div class=\"num\" id=\"statFiltered\">0</div><div class=\"lbl\">En el filtro actual</div></div>\r\n      </div>\r\n\r\n      <div class=\"filters-card\">\r\n        <div class=\"filters-grid\">\r\n          <div>\r\n            <label for=\"qName\">Buscar por nombre</label>\r\n            <input type=\"text\" id=\"qName\" placeholder=\"Escribe un nombre…\" autocomplete=\"off\">\r\n          </div>\r\n          <div>\r\n            <label for=\"qFrom\">Desde</label>\r\n            <input type=\"date\" id=\"qFrom\">\r\n          </div>\r\n          <div>\r\n            <label for=\"qTo\">Hasta</label>\r\n            <input type=\"date\" id=\"qTo\">\r\n          </div>\r\n        </div>\r\n        <div class=\"chips\" id=\"interestChips\">\r\n          <button class=\"chip active\" data-int=\"\" type=\"button\">Todos</button>\r\n          <button class=\"chip\" data-int=\"caldera\" type=\"button\">Caldera</button>\r\n          <button class=\"chip\" data-int=\"aire\" type=\"button\">Aire acondicionado</button>\r\n          <button class=\"chip\" data-int=\"otro\" type=\"button\">Otros</button>\r\n        </div>\r\n      </div>\r\n\r\n      <div id=\"leadsList\"></div>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<div id=\"toast\"></div>";
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script>(function(){try{var t=localStorage.getItem("decogas_theme");if(t!=="dark"&&t!=="light")t=(window.matchMedia&&matchMedia("(prefers-color-scheme:dark)").matches)?"dark":"light";document.documentElement.setAttribute("data-theme",t);}catch(e){}})();</script>
<meta name="robots" content="noindex, nofollow">
<title>Clientes — Decogas</title>
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=IBM+Plex+Mono:wght@500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style is:inline set:html={css}></style>
</head>
<body>
<Fragment set:html={body} />
<script src="vendor/supabase.min.js?v=1" is:inline></script>
<script src={`${base}utils.js?v=${V}`} is:inline></script>
<script src={`${base}config.js?v=${V}`} is:inline></script>
<script src={`${base}clientes.js?v=${V}`} is:inline></script>
<script>(function(){var b=document.getElementById("themeToggle");if(!b)return;b.addEventListener("click",function(){var d=document.documentElement.getAttribute("data-theme")==="dark";var n=d?"light":"dark";document.documentElement.setAttribute("data-theme",n);try{localStorage.setItem("decogas_theme",n);}catch(e){}});})();</script>
</body>
</html>
