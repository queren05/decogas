---
import Base from '../layouts/Base.astro';
const title = "Guías y consejos · Decogas Madrid";
const description = "Guías y consejos de Decogas sobre calderas, aire acondicionado y aerotermia: precios, averías, mantenimiento y cómo elegir bien tu equipo.";
const scripts = ["utils.js","config.js","prices.js","data-calderas.js","data-aires.js","search.js","data-guias.js","guias.js","app.js"];
const headExtras = "<link rel=\"canonical\" href=\"https://queren05.github.io/decogas/guias.html\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"Guías y consejos · Decogas Madrid\">\n<meta property=\"og:description\" content=\"Guías y consejos de Decogas sobre calderas, aire acondicionado y aerotermia: precios, averías, mantenimiento y cómo elegir bien tu equipo.\">\n<meta property=\"og:url\" content=\"https://queren05.github.io/decogas/guias.html\">\n<meta property=\"og:image\" content=\"https://queren05.github.io/decogas/hero-bg.jpg\">\n<meta property=\"og:locale\" content=\"es_ES\">\n<link rel=\"preload\" as=\"image\" href=\"hero-bg.jpg\">";
const body = "<!-- HERO -->\r\n<section class=\"hero\" id=\"top\">\r\n  <div class=\"hero-orb orb-1\"></div>\r\n  <div class=\"hero-orb orb-2\"></div>\r\n  <div class=\"hero-orb orb-3\"></div>\r\n  <div class=\"wrap page-hero\" style=\"display:block; max-width:720px;\">\r\n    <div class=\"breadcrumb\"><a href=\"index.html\">Inicio</a> / Guías y consejos</div>\r\n    <div class=\"eyebrow\" style=\"color:var(--flame);\">Más información</div>\r\n    <h1 style=\"color:#fff; font-size:clamp(34px,5vw,52px); margin-bottom:16px;\">Guías y consejos de nuestros expertos</h1>\r\n    <p class=\"lead\">177 guías escritas por nuestro equipo: cuánto cuesta cada equipo, cómo elegirlo, averías típicas y su solución, y trucos de mantenimiento. Todo explicado en claro.</p>\r\n  </div>\r\n</section>\r\n\r\n<!-- GUÍAS -->\r\n<section class=\"section\" style=\"padding-top:56px;\">\r\n  <div class=\"wrap\">\r\n    <div class=\"catalog-search reveal\">\r\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#5B6B7B\" stroke-width=\"2.2\" stroke-linecap=\"round\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"m21 21-4.3-4.3\"/></svg>\r\n      <input type=\"text\" id=\"guideSearch\" placeholder=\"Busca una guía (avería, precio, marca…)\" autocomplete=\"off\">\r\n    </div>\r\n    <div class=\"filter-bar reveal\" id=\"guideChips\">\r\n      <button class=\"filter-btn active\" data-cat=\"\" type=\"button\">Todas</button>\r\n      <button class=\"filter-btn\" data-cat=\"caldera\" type=\"button\">Calderas</button>\r\n      <button class=\"filter-btn\" data-cat=\"aire\" type=\"button\">Aire acondicionado</button>\r\n      <button class=\"filter-btn\" data-cat=\"aerotermia\" type=\"button\">Aerotermia</button>\r\n    </div>\r\n    <div class=\"guide-grid\" id=\"guideGrid\"></div>\r\n  </div>\r\n</section>";
---
<Base title={title} description={description} dataPage="guias" scripts={scripts}>
  <Fragment slot="head" set:html={headExtras} />
  <Fragment set:html={body} />
</Base>
