---
import Base from '../layouts/Base.astro';
const SB = new URL(import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/', Astro.site).href; // URL absoluta del sitio (sigue a SITE/BASE)
const title = "Termos y calentadores · Decogas Madrid";
const description = "Termos eléctricos y calentadores de gas con instalación incluida en Madrid. Presupuesto cerrado, financiación sin intereses e instalación en 24/48h.";
const scripts = ["utils.js","config.js","prices.js","data-termos.js","data-aires.js","catalog.js","search.js","app.js"];
const headExtras = "<link rel=\"canonical\" href=\"https://queren05.github.io/decogas/termos.html\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"Termos y calentadores · Decogas Madrid\">\n<meta property=\"og:description\" content=\"Termos eléctricos y calentadores de gas con instalación incluida en Madrid. Presupuesto cerrado, financiación sin intereses e instalación en 24/48h.\">\n<meta property=\"og:url\" content=\"https://queren05.github.io/decogas/termos.html\">\n<meta property=\"og:image\" content=\"https://queren05.github.io/decogas/hero-bg.jpg\">\n<meta property=\"og:locale\" content=\"es_ES\">\n<link rel=\"preload\" as=\"image\" href=\"hero-bg.jpg\">";
const body = "<!-- HERO -->\r\n<section class=\"hero\" id=\"top\">\r\n  <div class=\"hero-orb orb-1\"></div>\r\n  <div class=\"hero-orb orb-2\"></div>\r\n  <div class=\"hero-orb orb-3\"></div>\r\n  <div class=\"wrap page-hero\" style=\"display:block; max-width:720px;\">\r\n    <div class=\"breadcrumb\"><a href=\"index.html\">Inicio</a> / Termos y calentadores</div>\r\n    <div class=\"eyebrow\" style=\"color:var(--flame);\">Agua caliente</div>\r\n    <h1 style=\"color:#fff; font-size:clamp(34px,5vw,52px); margin-bottom:16px;\">Termos y calentadores, instalados en 24/48h</h1>\r\n    <p class=\"lead\">Termos eléctricos y calentadores de gas de marcas de referencia, con presupuesto claro y técnicos certificados RITE. Elige tu equipo y te llamamos para cerrar la visita técnica.</p>\r\n    <div class=\"hero-ctas\" style=\"margin-top:26px;\">\r\n      <a href=\"index.html#contacto\" class=\"btn btn-flame\">Pedir presupuesto</a>\r\n      <a href=\"tel:+34919930168\" class=\"btn btn-ghost\">Llamar · 919 93 01 68</a>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<div class=\"marquee\">\r\n  <div class=\"marquee-track\">\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>Instalación en <b>24/48h</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"2\" y=\"5\" width=\"20\" height=\"14\" rx=\"2\"/><line x1=\"2\" y1=\"10\" x2=\"22\" y2=\"10\"/></svg>Financiación a <b>12, 24 y 36 meses</b> sin intereses</span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14.7 6.3a4.5 4.5 0 0 0-6.4 6.4l7 7a2 2 0 0 0 2.8-2.8z\"/><path d=\"m5 21 4-4\"/></svg>Instalamos tu aire o caldera (propiedad del cliente) <b>desde 350€</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2 4 5v6c0 5 3.4 9.4 8 11 4.6-1.6 8-6 8-11V5z\"/></svg>Garantía de <b>3 años</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"/></svg>Certificados <b>RITE</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg><b>4.7★</b> en Google · +780 reseñas</span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/></svg>Técnicos <b>propios</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polyline points=\"12 6 12 12 16 14\"/></svg>Instalación en <b>24/48h</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"2\" y=\"5\" width=\"20\" height=\"14\" rx=\"2\"/><line x1=\"2\" y1=\"10\" x2=\"22\" y2=\"10\"/></svg>Financiación a <b>12, 24 y 36 meses</b> sin intereses</span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M14.7 6.3a4.5 4.5 0 0 0-6.4 6.4l7 7a2 2 0 0 0 2.8-2.8z\"/><path d=\"m5 21 4-4\"/></svg>Instalamos tu aire o caldera (propiedad del cliente) <b>desde 350€</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 2 4 5v6c0 5 3.4 9.4 8 11 4.6-1.6 8-6 8-11V5z\"/></svg>Garantía de <b>3 años</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 6 9 17l-5-5\"/></svg>Certificados <b>RITE</b></span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg><b>4.7★</b> en Google · +780 reseñas</span>\r\n    <span class=\"marquee-item\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/></svg>Técnicos <b>propios</b></span>\r\n  </div>\r\n</div>\r\n\r\n<div class=\"install-banner\">\r\n  <div class=\"wrap\">\r\n    <div class=\"icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M9 12l2 2 4-4\"/><circle cx=\"12\" cy=\"12\" r=\"10\"/></svg></div>\r\n    <div>\r\n      <h4>Instalación básica incluida en el precio</h4>\r\n      <p>Todas las calderas incluyen 80 cm de tubo de salida de humos y 3 m de conexión a desagüe. Si tu instalación necesita alguna pieza adicional, se cobra a 36,30€/ud.</p>\r\n    </div>\r\n  </div>\r\n</div>\r\n\r\n<!-- CATÁLOGO -->\r\n<section class=\"products-section\">\r\n  <div class=\"wrap\">\r\n    <div class=\"section-head reveal\">\r\n      <div class=\"eyebrow\">Catálogo</div>\r\n      <h2>Nuestras calderas de gas</h2>\r\n      <p>Selección de las referencias más solicitadas, con caudalímetro y termostato incluidos. Filtra por marca o por precio.</p>\r\n    </div>\r\n\r\n    <div class=\"catalog-search reveal\">\r\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#5B6B7B\" stroke-width=\"2.2\" stroke-linecap=\"round\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"m21 21-4.3-4.3\"/></svg>\r\n      <input type=\"text\" id=\"catalogSearch\" placeholder=\"Busca por nombre o marca…\" autocomplete=\"off\">\r\n    </div>\r\n    <div class=\"filter-bar reveal\" id=\"filterBar\">\r\n      <button class=\"filter-btn active\" data-filter=\"all\">\r\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"16\" rx=\"2\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/></svg>\r\n        Todo\r\n      </button>\r\n      <button class=\"filter-btn\" data-filter=\"brand\">\r\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1.5\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1.5\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1.5\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1.5\"/></svg>\r\n        Por marcas\r\n      </button>\r\n      <button class=\"filter-btn\" data-filter=\"pop\">\r\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M10 1l2.6 5.9 6.4.6-4.8 4.3 1.4 6.3L10 14.9 4.4 18l1.4-6.3L1 7.5l6.4-.6z\"/></svg>\r\n        Más vendido\r\n      </button>\r\n      <button class=\"filter-btn\" data-filter=\"cheap\">\r\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 19V5M5 12l7-7 7 7\"/></svg>\r\n        Más barato\r\n      </button>\r\n      <button class=\"filter-btn\" data-filter=\"expensive\">\r\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14M5 12l7 7 7-7\"/></svg>\r\n        Más caro\r\n      </button>\r\n      <button class=\"filter-btn\" data-filter=\"tipo\">\r\n        <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"m6 9 6 6 6-6\"/></svg>\r\n        Tipo\r\n      </button>\r\n    </div>\r\n    <div class=\"sub-filter-bar\" id=\"subFilterBar\">\r\n      <button class=\"sub-chip\" data-type=\"termo\" type=\"button\">Termos eléctricos</button>\r\n      <button class=\"sub-chip\" data-type=\"calentador\" type=\"button\">Calentadores de gas</button>\r\n    </div>\r\n\r\n    <div id=\"catalogRoot\"></div>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"extra-costs\" style=\"background:var(--cloud);\">\r\n  <div class=\"wrap\">\r\n    <div class=\"box reveal\">\r\n      <div class=\"icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 8v4M12 16h.01\"/></svg></div>\r\n      <div>\r\n        <h3>¿Qué incluye y qué no la instalación básica?</h3>\r\n        <p>El precio de cada caldera incluye una instalación estándar con <strong style=\"color:var(--navy);\">80 cm de tubo de salida de humos</strong> y <strong style=\"color:var(--navy);\">3 m de conexión a desagüe</strong>.</p>\r\n        <p>Si tu vivienda necesita alguna pieza adicional (más metros de tubo, codos, adaptadores, etc.), se factura a <span class=\"price-tag\">36,30€/ud.</span> Nuestro técnico te lo confirma en la visita, antes de instalar nada.</p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<section class=\"final-cta\">\r\n  <div class=\"wrap\">\r\n    <h2>¿Dudas sobre qué caldera elegir?</h2>\r\n    <p>Cuéntanos el tamaño de tu vivienda y tu consumo actual: te recomendamos el modelo adecuado sin compromiso.</p>\r\n    <a href=\"index.html#contacto\" class=\"btn btn-white\">Pedir asesoramiento</a>\r\n  </div>\r\n</section>";
---
<Base title={title} description={description} dataPage="termos" scripts={scripts}>
  <Fragment slot="head" set:html={headExtras.split('https://queren05.github.io/decogas/').join(SB)} />
  <Fragment set:html={body} />
</Base>
