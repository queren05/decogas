---
// Página por marca: lista todos los productos visibles del fabricante con
// enlace a su ficha. Generadas en el build desde Supabase (ver lib/productos).
import Base from '../../layouts/Base.astro';
import { fetchProductosVisibles, agruparPorMarca } from '../../lib/productos.mjs';

export async function getStaticPaths() {
  const productos = await fetchProductosVisibles();
  return agruparPorMarca(productos).map((m) => ({ params: { marca: m.slug }, props: { m } }));
}

const { m } = Astro.props;
const SB = new URL(import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/', Astro.site).href;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const LOGO = {
  'hisense': 'hisense.jpg', 'saunier-duval': 'saunier-duval.jpg',
  'mitsubishi-electric': 'mitsubishi-electric.svg', 'daikin': 'daikin.svg',
  'fujitsu': 'fujitsu.svg', 'bosch': 'bosch.jpg', 'hermann': 'hermann.jpg',
  'vaillant': 'vaillant.jpg', 'demirdokum': 'demirdokum.jpg',
};
const fmt = (n) => Number(n).toLocaleString('es-ES');
const cuota36 = (n) => fmt(Math.ceil((Number(n) / 36) * 100) / 100);
const CAT_NOMBRE = { calderas: 'Calderas', aires: 'Aire acondicionado', termos: 'Termos y calentadores' };
const cats = [...new Set(m.productos.map((p) => p.category))];
const title = `${m.brand}: catálogo con instalación · Decogas Madrid`;
const description = `${m.productos.length} equipos ${m.brand} con instalación incluida en Madrid: ${cats.map((c) => (CAT_NOMBRE[c] || c).toLowerCase()).join(', ')}. Precios con IVA y financiación sin intereses.`;
const scripts = ['utils.js', 'config.js', 'prices.js', 'data-calderas.js', 'data-aires.js', 'data-termos.js', 'search.js', 'recientes.js', 'app.js'];

const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `Catálogo ${m.brand} en Decogas`,
  itemListElement: m.productos.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: `${SB}producto/${p.slug}.html`,
  })),
});
---
<Base title={title} description={description} dataPage="marca" scripts={scripts}>
  <Fragment slot="head">
    <link rel="canonical" href={`${SB}marcas/${m.slug}.html`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`${SB}marcas/${m.slug}.html`} />
    <script type="application/ld+json" set:html={ld} is:inline></script>
  </Fragment>

  <section class="hero" style="min-height:auto; padding:160px 0 60px;">
    <div class="hero-orb orb-1"></div>
    <div class="wrap page-hero" style="display:block; max-width:820px;">
      <div class="breadcrumb"><a href={`${SB}index.html`}>Inicio</a> / <a href={`${SB}marcas.html`}>Marcas</a> / {m.brand}</div>
      <div class="eyebrow" style="color:var(--flame);">Instaladores oficiales</div>
      {LOGO[m.slug] && <span class="marca-hero-logo"><img src={`${base}marcas/${LOGO[m.slug]}`} alt={m.brand} /></span>}
      <h1 style="color:#fff; font-size:clamp(32px,4.6vw,48px); margin-bottom:14px;">{m.brand}</h1>
      <p class="lead">{m.productos.length} equipos con precio cerrado: IVA e instalación estándar incluidos, y financiación a 12, 24 o 36 meses sin intereses.</p>
      {m.slug === 'hisense' && (
        <span class="sponsor-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18M3.5 9h17M3.5 15h17"/></svg>
          Hisense, patrocinador oficial de la Copa Mundial de la FIFA 2026™
        </span>
      )}
    </div>
  </section>

  <section class="section" style="padding-top:50px;">
    <div class="wrap">
      {cats.map((cat) => (
        <div class="marca-bloque">
          <h2 class="marca-cat reveal">{CAT_NOMBRE[cat] || cat}</h2>
          <div class="marca-grid reveal-stagger">
            {m.productos.filter((p) => p.category === cat).map((p) => (
              <a class="marca-card" href={`${SB}producto/${p.slug}.html`}>
                <div class="marca-visual">
                  {p.img ? <img src={p.img} alt={p.name} loading="lazy" /> : <span class="marca-noimg">Foto próximamente</span>}
                  {p.best && <span class="marca-best">Más vendido</span>}
                </div>
                <div class="marca-body">
                  <div class="marca-name">{p.name}</div>
                  {Array.isArray(p.specs) && p.specs.length > 0 && (
                    <div class="marca-specs">{p.specs.slice(0, 2).join(' · ')}</div>
                  )}
                  <div class="marca-price"><strong>{fmt(p.price)} €</strong> <span>o desde {cuota36(p.price)} €/mes</span></div>
                  <span class="marca-more">Ver ficha →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}

      <div class="prod-back reveal">
        <a class="btn btn-navy" href={`${SB}marcas.html`}>← Todas las marcas</a>
      </div>
    </div>
  </section>
</Base>
