---
import Base from '../layouts/Base.astro';
const SB = new URL(import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/', Astro.site).href; // URL absoluta del sitio (sigue a SITE/BASE)
const title = "Calcula tu equipo · Decogas Madrid";
const description = "Calcula gratis qué potencia de caldera o de aire acondicionado necesita tu vivienda y descubre el equipo recomendado. Decogas Madrid.";
const scripts = ["utils.js","config.js","prices.js","data-calderas.js","data-aires.js","search.js","calcula.js","app.js"];
const headExtras = "<link rel=\"canonical\" href=\"https://queren05.github.io/decogas/calcula.html\">\n<meta property=\"og:type\" content=\"website\">\n<meta property=\"og:title\" content=\"Calcula tu equipo · Decogas Madrid\">\n<meta property=\"og:description\" content=\"Calcula gratis qué potencia de caldera o de aire acondicionado necesita tu vivienda y descubre el equipo recomendado de nuestro catálogo. Decogas Madrid.\">\n<meta property=\"og:url\" content=\"https://queren05.github.io/decogas/calcula.html\">\n<meta property=\"og:image\" content=\"https://queren05.github.io/decogas/hero-bg.jpg\">\n<meta property=\"og:locale\" content=\"es_ES\">\n<link rel=\"preload\" as=\"image\" href=\"hero-bg.jpg\">";
const body = "<!-- HERO -->\r\n<section class=\"hero\" id=\"top\">\r\n  <div class=\"hero-orb orb-1\"></div>\r\n  <div class=\"hero-orb orb-2\"></div>\r\n  <div class=\"hero-orb orb-3\"></div>\r\n  <div class=\"wrap page-hero\" style=\"display:block; max-width:720px;\">\r\n    <div class=\"breadcrumb\"><a href=\"index.html\">Inicio</a> / Calculadora</div>\r\n    <div class=\"eyebrow\" style=\"color:var(--flame);\">Herramienta gratuita</div>\r\n    <h1 style=\"color:#fff; font-size:clamp(34px,5vw,52px); margin-bottom:16px;\">Calcula qué equipo necesita tu vivienda</h1>\r\n    <p class=\"lead\">Dinos cuántos metros tiene tu casa y te decimos la potencia mínima, la recomendada y el equipo de nuestro catálogo que mejor encaja. Sin registros y en 10 segundos.</p>\r\n  </div>\r\n</section>\r\n\r\n<!-- CALCULADORA -->\r\n<section class=\"section\" style=\"padding-top:56px;\">\r\n  <div class=\"wrap\">\r\n    <div class=\"calc-tabs reveal\">\r\n      <button class=\"calc-tab active\" data-panel=\"calcCalderas\" type=\"button\">\r\n        <svg width=\"17\" height=\"17\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"7\" y=\"2\" width=\"10\" height=\"20\" rx=\"2\"/><circle cx=\"10.5\" cy=\"7\" r=\"1.3\"/><circle cx=\"13.5\" cy=\"7\" r=\"1.3\"/><path d=\"M9.5 16c.8-1.2 1.7-1.2 2.5 0s1.7 1.2 2.5 0\"/></svg>\r\n        Caldera\r\n      </button>\r\n      <button class=\"calc-tab\" data-panel=\"calcAires\" type=\"button\">\r\n        <svg width=\"17\" height=\"17\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"2\" y=\"5\" width=\"20\" height=\"9\" rx=\"2.5\"/><path d=\"M5 17c1-1.4 2-1.4 3 0M10.5 18c1-1.4 2-1.4 3 0M16 17c1-1.4 2-1.4 3 0\"/></svg>\r\n        Aire acondicionado\r\n      </button>\r\n    </div>\r\n\r\n    <!-- ============ PANEL CALDERAS ============ -->\r\n    <div class=\"calc-panel active\" id=\"calcCalderas\">\r\n      <div class=\"calc-grid\">\r\n        <div class=\"calc-card reveal\">\r\n          <h3>Tu vivienda</h3>\r\n          <div class=\"calc-field\">\r\n            <label>Superficie a calefactar · <span class=\"value-badge\" id=\"cM2Val\">90 m²</span></label>\r\n            <input type=\"range\" id=\"cM2\" min=\"40\" max=\"250\" step=\"5\" value=\"90\">\r\n          </div>\r\n          <div class=\"calc-field\">\r\n            <label>Número de baños</label>\r\n            <div class=\"calc-choices\" id=\"cBanos\">\r\n              <button class=\"calc-choice active\" data-value=\"1\" type=\"button\">1 baño</button>\r\n              <button class=\"calc-choice\" data-value=\"2\" type=\"button\">2 baños</button>\r\n              <button class=\"calc-choice\" data-value=\"3\" type=\"button\">3 o más</button>\r\n            </div>\r\n          </div>\r\n          <button class=\"btn btn-flame\" id=\"cCalc\" type=\"button\" style=\"width:100%; margin-top:6px;\">Calcular mi caldera</button>\r\n          <p class=\"calc-note\">Cálculo orientativo basado en los criterios habituales de dimensionado (el agua caliente sanitaria marca la potencia en calderas mixtas). La visita técnica gratuita confirma la potencia exacta.</p>\r\n        </div>\r\n\r\n        <div class=\"calc-result\" id=\"cResult\">\r\n          <div class=\"power-row\">\r\n            <div class=\"power-box\"><div class=\"pw-label\">Potencia mínima</div><div class=\"pw-value\" id=\"cMin\">—</div></div>\r\n            <div class=\"power-box rec\"><div class=\"pw-label\">Recomendada</div><div class=\"pw-value\" id=\"cRec\">—</div></div>\r\n          </div>\r\n          <div id=\"cReco\"></div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- ============ PANEL AIRES ============ -->\r\n    <div class=\"calc-panel\" id=\"calcAires\">\r\n      <div class=\"calc-grid\">\r\n        <div class=\"calc-card reveal\">\r\n          <h3>Tu estancia</h3>\r\n          <div class=\"calc-field\">\r\n            <label>Superficie a climatizar · <span class=\"value-badge\" id=\"aM2Val\">25 m²</span></label>\r\n            <input type=\"range\" id=\"aM2\" min=\"10\" max=\"60\" step=\"1\" value=\"25\">\r\n          </div>\r\n          <div class=\"calc-field\">\r\n            <label>¿Cuántas estancias quieres climatizar?</label>\r\n            <div class=\"calc-choices\" id=\"aEstancias\">\r\n              <button class=\"calc-choice active\" data-value=\"1\" type=\"button\">1 estancia</button>\r\n              <button class=\"calc-choice\" data-value=\"2\" type=\"button\">2 estancias (2x1)</button>\r\n            </div>\r\n          </div>\r\n          <div class=\"calc-field\">\r\n            <label>¿Le da mucho el sol? (orientación sur, ático…)</label>\r\n            <div class=\"calc-choices\" id=\"aSol\">\r\n              <button class=\"calc-choice active\" data-value=\"no\" type=\"button\">Sol normal</button>\r\n              <button class=\"calc-choice\" data-value=\"si\" type=\"button\">Mucho sol</button>\r\n            </div>\r\n          </div>\r\n          <button class=\"btn btn-flame\" id=\"aCalc\" type=\"button\" style=\"width:100%; margin-top:6px;\">Calcular mi aire</button>\r\n          <p class=\"calc-note\">Regla orientativa de ~100 frigorías por m² (+20% con alta exposición solar). Para 2 estancias, la superficie es la de la estancia más grande. La visita técnica gratuita lo confirma.</p>\r\n        </div>\r\n\r\n        <div class=\"calc-result\" id=\"aResult\">\r\n          <div class=\"power-row\">\r\n            <div class=\"power-box\"><div class=\"pw-label\">Frigorías necesarias</div><div class=\"pw-value\" id=\"aMin\">—</div></div>\r\n            <div class=\"power-box rec\"><div class=\"pw-label\">Potencia frigorífica</div><div class=\"pw-value\" id=\"aRec\">—</div></div>\r\n          </div>\r\n          <div id=\"aReco\"></div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>\r\n\r\n<!-- CTA -->\r\n<section class=\"section\" style=\"padding-top:0;\">\r\n  <div class=\"wrap\">\r\n    <div class=\"calc-card reveal\" style=\"text-align:center; background:linear-gradient(160deg, #0E2238, #12293F); border:none; color:#fff;\">\r\n      <h3 style=\"color:#fff; font-size:24px;\">¿Dudas con el resultado?</h3>\r\n      <p style=\"color:rgba(255,255,255,.75); max-width:480px; margin:10px auto 20px; font-size:15px;\">Te hacemos una visita técnica gratuita y sin compromiso para confirmar la potencia exacta y darte presupuesto cerrado.</p>\r\n      <div style=\"display:flex; gap:12px; justify-content:center; flex-wrap:wrap;\">\r\n        <a href=\"tel:+34919930168\" class=\"btn btn-flame\">Llámanos: 919 93 01 68</a>\r\n        <a href=\"https://wa.me/34651368631\" target=\"_blank\" rel=\"noopener\" class=\"btn btn-white\">WhatsApp</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</section>";
---
<Base title={title} description={description} dataPage="calcula" scripts={scripts}>
  <Fragment slot="head" set:html={headExtras.split('https://queren05.github.io/decogas/').join(SB)} />
  <Fragment set:html={body} />
</Base>
