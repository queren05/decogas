---
import Base from '../layouts/Base.astro';
const title = "Página no encontrada · Decogas";
const scripts = ["utils.js","config.js","prices.js","data-calderas.js","data-aires.js","search.js","app.js"];
const headExtras = "<meta name=\"robots\" content=\"noindex\">";
const body = "<section class=\"hero\" style=\"min-height:auto; padding:170px 0 90px;\">\r\n  <div class=\"hero-orb orb-1\"></div>\r\n  <div class=\"hero-orb orb-2\"></div>\r\n  <div class=\"wrap\" style=\"text-align:center; max-width:620px;\">\r\n    <div class=\"eyebrow\" style=\"color:var(--flame); justify-content:center;\">Error 404</div>\r\n    <h1 style=\"color:#fff; font-size:clamp(30px,5vw,46px); margin-bottom:14px;\">Esta página se nos ha escapado</h1>\r\n    <p class=\"lead\" style=\"margin:0 auto 26px;\">El enlace que has seguido no existe o ha cambiado de sitio. Pero seguimos aquí para ayudarte con tu caldera o tu aire acondicionado.</p>\r\n    <div style=\"display:flex; gap:12px; justify-content:center; flex-wrap:wrap;\">\r\n      <a href=\"/decogas/index.html\" class=\"btn btn-flame\">Volver al inicio</a>\r\n      <a href=\"/decogas/calderas.html\" class=\"btn btn-white\">Ver calderas</a>\r\n      <a href=\"/decogas/aires.html\" class=\"btn btn-white\">Ver aire acondicionado</a>\r\n    </div>\r\n    <p style=\"margin-top:24px; font-size:14px; color:rgba(255,255,255,.6);\">¿Prefieres que te llamemos? <a href=\"tel:+34919930168\" style=\"color:var(--flame); font-weight:600;\">919 93 01 68</a></p>\r\n  </div>\r\n</section>";
---
<Base title={title} dataPage="404" scripts={scripts}>
  <Fragment slot="head" set:html={headExtras} />
  <Fragment set:html={body} />
</Base>
