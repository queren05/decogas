---
// Layout base de Decogas: <head> común, header + menú móvil, footer y wa-float.
// Se escribe UNA vez y lo comparten todas las páginas raíz de marketing.
const rawBase = import.meta.env.BASE_URL; // '/decogas' (sin barra final)
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/'; // → '/decogas/'
const ASSET_V = 24; // cache-busting de los scripts clásicos (?v=N) — cambiar aquí, no en 187 archivos
const STYLES_V = 26; // styles.css va un paso por delante (fichas, ahorro, FAQ y mini-CRM v26)
// Página actual (formato 'file': /decogas/calderas.html) para marcar el menú activo
const currentFile = Astro.url.pathname.split('/').pop() || 'index.html';
const active = (file: string) => (currentFile === file ? 'page' : undefined);

export interface Props {
  title: string;
  description?: string;
  dataPage?: string;
  scripts?: string[]; // nombres de archivo en public/, en orden de carga
}

const { title, description = '', dataPage, scripts = [] } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
{description && <meta name="description" content={description}>}
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href={`${base}styles.css?v=${STYLES_V}`}>
<slot name="head" />
</head>
<body data-page={dataPage}>

<div class="scroll-progress" id="scrollProgress"></div>

<header id="siteHeader">
  <div class="wrap header-inner">
    <a href={`${base}index.html#top`} class="logo"><span class="dot"></span>DECOGAS</a>
    <nav class="main-nav">
      <a href={`${base}calderas.html`} aria-current={active('calderas.html')}>Calderas</a>
      <a href={`${base}aires.html`} aria-current={active('aires.html')}>Aire acondicionado</a>
      <a href={`${base}termos.html`} aria-current={active('termos.html')}>Termos</a>
      <a href={`${base}calcula.html`} aria-current={active('calcula.html')}>Calculadora</a>
      <a href={`${base}guias.html`} aria-current={active('guias.html')}>Guías</a>
      <a href={`${base}index.html#historia`}>Quiénes somos</a>
      <a href={`${base}index.html#resenas`}>Reseñas</a>
      <a href={`${base}index.html#contacto`}>Contacto</a>
    </nav>
    <div class="header-actions">
      <button class="search-btn" id="searchBtn" aria-label="Buscar producto">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <a href={`${base}index.html#contacto`} class="btn btn-flame">Pide información</a>
      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
      </button>
    </div>
  </div>
</header>

<div class="search-backdrop" id="searchBackdrop"></div>
<div class="search-overlay" id="searchOverlay">
  <div class="wrap">
    <div class="search-box">
      <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#5B6B7B" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" id="globalSearch" placeholder="Busca tu caldera o aire acondicionado…" autocomplete="off">
      <button class="search-close" id="searchClose" type="button">ESC</button>
    </div>
    <div class="search-results" id="searchResults"></div>
  </div>
</div>

<div class="mobile-nav" id="mobileNav">
  <button class="close-btn" id="navClose" aria-label="Cerrar menú">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
  </button>
  <a href={`${base}calderas.html`} aria-current={active('calderas.html')}>Calderas</a>
  <a href={`${base}aires.html`} aria-current={active('aires.html')}>Aire acondicionado</a>
  <a href={`${base}termos.html`} aria-current={active('termos.html')}>Termos y calentadores</a>
  <a href={`${base}calcula.html`} aria-current={active('calcula.html')}>Calculadora</a>
  <a href={`${base}guias.html`} aria-current={active('guias.html')}>Guías y consejos</a>
  <a href={`${base}index.html#historia`}>Quiénes somos</a>
  <a href={`${base}index.html#resenas`}>Reseñas</a>
  <a href={`${base}index.html#contacto`}>Contacto</a>
  <a href="tel:+34919930168" class="mono" style="font-size:18px; color:var(--flame);">919 93 01 68</a>
</div>

<slot />

<footer>
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div class="footer-logo">DECOGAS</div>
        <p style="font-size:14px; margin-bottom:6px;">Empresa familiar de climatización en Madrid. Calderas de gas, aire acondicionado y aerotermia.</p>
        <p style="font-size:14px;">C. de los Almendros, 8, Local 6 A<br>28821 Coslada, Madrid</p>
        <div class="social-row">
          <a href="https://www.facebook.com/somosdecogas" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
          <a href="https://wa.me/34651368631" target="_blank" rel="noopener" aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></a>
          <a href="https://maps.app.goo.gl/MJmhobTFJWzdnL6p7" target="_blank" rel="noopener" aria-label="Google Maps"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 21s7-6.5 7-11a7 7 0 1 0-14 0c0 4.5 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></a>
        </div>
      </div>
      <div>
        <h5>La empresa</h5>
        <ul>
          <li><a href={`${base}index.html#historia`}>Quiénes somos</a></li>
          <li><a href={`${base}index.html#resenas`}>Reseñas de Google</a></li>
          <li><a href={`${base}index.html#zona`}>Zona de servicio</a></li>
          <li><a href={`${base}index.html#subvenciones`}>Ayudas y subvenciones</a></li>
          <li><a href={`${base}guias.html`}>Guías y consejos</a></li>
          <li><a href={`${base}faq.html`}>Preguntas frecuentes</a></li>
          <li><a href={`${base}ahorro.html`}>Comparador de ahorro</a></li>
          <li><a href={`${base}legal.html`}>Aviso legal y privacidad</a></li>
          <li><a href={`${base}calcula.html`}>Calculadora de equipo</a></li>
          <li><a href={`${base}index.html#contacto`}>Pide información</a></li>
        </ul>
      </div>
      <div>
        <h5>Contacto</h5>
        <ul>
          <li><a href="tel:+34919930168">919 93 01 68</a></li>
          <li><a href="mailto:info@decogas.com">info@decogas.com</a></li>
          <li><a href="https://wa.me/34651368631" target="_blank" rel="noopener">WhatsApp</a></li>
          <li>Lunes a viernes, 9:00–14:00 / 16:00–19:00</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Decogas — INSTALADORES DECOGAS SL · CIF B88192075</span>
      <span>Instaladores autorizados por RITE</span>
    </div>
  </div>
</footer>

<a href="https://wa.me/34651368631" target="_blank" rel="noopener" class="wa-float" aria-label="WhatsApp">
  <svg viewBox="0 0 24 24"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.87.5 3.62 1.44 5.15L2 22l5.09-1.53a9.87 9.87 0 0 0 4.95 1.31h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm5.79 14.16c-.24.68-1.4 1.3-1.93 1.36-.5.06-1.03.29-3.46-.72-2.91-1.21-4.78-4.15-4.93-4.35-.14-.19-1.17-1.56-1.17-2.98 0-1.41.74-2.1 1-2.39.26-.28.57-.36.77-.36.19 0 .38.001.55.01.18.01.42-.07.65.5.24.58.82 2 .9 2.15.07.14.12.31.02.5-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.75 1.24 1.61 2 1.1.98 2.03 1.29 2.32 1.43.29.15.46.12.63-.07.17-.19.72-.84.92-1.13.19-.29.38-.24.65-.14.26.1 1.66.78 1.95.92.28.15.47.22.54.34.07.13.07.72-.17 1.4z"/></svg>
</a>

{scripts.map((s) => <script src={`${base}${s}?v=${ASSET_V}`} is:inline></script>)}

</body>
</html>
