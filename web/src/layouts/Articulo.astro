---
// Layout de artículo de blog: reconstruye el <section class="article-hero"> (breadcrumb +
// tag + h1 + meta) y el bloque CTA de cierre, replicando el markup/clases del HTML original
// para que el styles.css actual lo pinte idéntico. El cuerpo (article-prose) llega por <slot/>.
import Base from './Base.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const d = post.data;

// Artículos relacionados: 3 de la misma categoría (mejora SEO e interlinking).
const all = await getCollection('blog');
let related = all.filter((p) => p.id !== post.id && p.data.category === d.category);
if (related.length < 3) related = related.concat(all.filter((p) => p.id !== post.id && p.data.category !== d.category));
related = related.slice(0, 3);

// Scripts clásicos en el mismo orden que servían los artículos antiguos.
const scripts = [
  'utils.js', 'config.js', 'prices.js',
  'data-calderas.js', 'data-aires.js', 'search.js', 'app.js',
];

// CTA de cierre — determinado por categoría (idéntico al HTML original, verificado 1:1).
const CTA: Record<string, { title: string; href: string }> = {
  'caldera':            { title: '¿Necesitas ayuda con tu caldera?',            href: base + 'calderas.html' },
  'aire-acondicionado': { title: '¿Necesitas ayuda con tu aire acondicionado?', href: base + 'aires.html' },
  'aerotermia':         { title: '¿Necesitas ayuda con aerotermia?',            href: base + 'index.html#contacto' },
  'blog':               { title: '¿Necesitas ayuda con tu equipo?',             href: base + 'index.html' },
};
const cta = CTA[d.category] ?? CTA['blog'];

const meta = d.readingTime != null
  ? ` · ${d.readingTime} min de lectura · Por el equipo de Decogas`
  : ' · Por el equipo de Decogas';

// URL canónica idéntica a la del sitio antiguo: dominio + base + ruta del blog + barra final.
const site = (Astro.site?.href ?? 'https://queren05.github.io/').replace(/\/$/, '');
const canonical = `${site}${base}blog/${post.id}/`;

// Imagen destacada del artículo: la 1ª imagen del cuerpo (ya self-hosteada).
const firstImg = (post.body?.match(/!\[[^\]]*\]\((\/[^)\s]+\.(?:webp|jpg|jpeg|png))\)/) || [])[1];
const imageAbs = firstImg ? site + firstImg : `${site}${base}hero-bg.jpg`;

// Datos estructurados: BlogPosting (Google entiende y recomienda mejor el artículo).
// No se inventa la fecha: los artículos no la traen (frontmatter sin `date`).
const articleLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  ...(d.description ? { description: d.description } : {}),
  image: imageAbs,
  inLanguage: 'es-ES',
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  author: { '@type': 'Organization', name: 'Decogas', url: `${site}${base}` },
  publisher: {
    '@type': 'Organization',
    name: 'INSTALADORES DECOGAS SL',
    logo: { '@type': 'ImageObject', url: `${site}${base}logo-decogas.png` },
  },
  ...(d.date ? { datePublished: d.date.toISOString(), dateModified: d.date.toISOString() } : {}),
});

// Migas estructuradas: Inicio › Guías › Artículo (Google muestra la ruta).
const breadcrumbLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${site}${base}index.html` },
    { '@type': 'ListItem', position: 2, name: 'Guías', item: `${site}${base}guias.html` },
    { '@type': 'ListItem', position: 3, name: d.breadcrumb || d.title, item: canonical },
  ],
});
---
<Base
  title={`${d.title} · Decogas Madrid`}
  description={d.description}
  dataPage="guias"
  scripts={scripts}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={d.title} />
    {d.description && <meta property="og:description" content={d.description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    {imageAbs && <meta property="og:image" content={imageAbs} />}
    <script type="application/ld+json" set:html={articleLd} is:inline></script>
    <script type="application/ld+json" set:html={breadcrumbLd} is:inline></script>
  </Fragment>

  <section class="article-hero">
    <div class="wrap">
      <div class="breadcrumb"><a href={`${base}index.html`}>Inicio</a> / <a href={`${base}guias.html`}>Guías</a> / {d.breadcrumb}</div>
      <span class={`guide-tag ${d.tagClass}`} style="display:inline-block; margin:14px 0 12px;">{d.tag}</span>
      <h1>{d.title}</h1>
      <div class="article-meta">{meta}</div>
    </div>
  </section>

  <article class="article-prose">
    <div class="wrap">
      <slot />
    </div>
  </article>

  {related.length > 0 && (
    <section class="section" style="padding:20px 0 0;">
      <div class="wrap" style="max-width:820px;">
        <h2 class="related-h2">Sigue leyendo</h2>
        <div class="related-grid">
          {related.map((r) => (
            <a class="related-card" href={`${base}blog/${r.id}/`}>
              <span class={`guide-tag ${r.data.tagClass}`}>{r.data.tag}</span>
              <span class="related-title">{r.data.title}</span>
              <span class="related-more">Leer la guía →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section" style="padding-top:0;">
    <div class="wrap">
      <div class="calc-card reveal" style="text-align:center; background:linear-gradient(160deg, #0E2238, #12293F); border:none; color:#fff;">
        <h3 style="color:#fff; font-size:23px;">{cta.title}</h3>
        <p style="color:rgba(255,255,255,.75); max-width:480px; margin:10px auto 20px; font-size:15px;">Visita técnica gratuita, presupuesto cerrado por escrito y financiación sin intereses. Más de 15 años instalando en Madrid.</p>
        <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
          <a href={cta.href} class="btn btn-flame">Ver catálogo y precios</a>
          <a href="tel:+34919930168" class="btn btn-white">919 93 01 68</a>
        </div>
      </div>
    </div>
  </section>
</Base>
